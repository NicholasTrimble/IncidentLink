@model IncidentLink.Models.Incident
@{
    ViewData["Title"] = "Incident Details";
}

<div class="max-w-2xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold">Incident Details</h1>

    <div class="bg-gray-900 border border-gray-800 p-6 rounded-xl space-y-2 text-gray-300">

        <div><span class="text-white">Title:</span> @Model.Title</div>
        <div><span class="text-white">Description:</span> @Model.Description</div>
        <div><span class="text-white">Severity:</span> @Model.Severity</div>
        <div><span class="text-white">Status:</span> @Model.Status</div>
        <div><span class="text-white">Location:</span> @Model.Location</div>
        <div><span class="text-white">Created:</span> @Model.CreatedAt</div>
        <div><span class="text-white">Resolved:</span> @Model.ResolvedAt</div>

    </div>

    <a asp-action="Edit" asp-route-id="@Model.Id"
           class="inline-block px-4 py-2 bg-blue-600 rounded-lg">
        Edit Incident
    </a>

</div>