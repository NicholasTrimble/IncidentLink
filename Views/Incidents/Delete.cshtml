@model IncidentLink.Models.Incident
@{
    ViewData["Title"] = "Delete Incident";
}

<div class="max-w-2xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold text-red-400">Delete Incident</h1>

    <div class="bg-gray-900 border border-gray-800 p-6 rounded-xl space-y-3">

        <p class="text-gray-300">Are you sure you want to delete this incident?</p>

        <div class="text-sm text-gray-400">
            <div><span class="text-white">Title:</span> @Model.Title</div>
            <div><span class="text-white">Location:</span> @Model.Location</div>
            <div><span class="text-white">Severity:</span> @Model.Severity</div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="flex gap-3 mt-4">
                <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg">
                    Delete
                </button>

                <a asp-action="Index" class="px-4 py-2 bg-gray-700 rounded-lg">
                    Cancel
                </a>
            </div>
        </form>

    </div>
</div>