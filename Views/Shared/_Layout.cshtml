<!DOCTYPE html>
<html lang="en" class="h-100">
<!-- Force the HTML tag to take full height -->
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IncidentLink</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column h-100">
    <!-- Flex column structure handles the spacing -->

    <header>
        <!-- Paste your working navbar code here exactly how you have it -->
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom border-secondary border-opacity-25 shadow-sm mb-3">
            <div class="container-fluid px-4">
                <a class="navbar-brand text-white fw-bold font-monospace tracking-wide" asp-area="" asp-controller="Home" asp-action="Index">
                    🚨 IncidentLink
                </a>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-white-50 px-3" asp-area="" asp-controller="Incidents" asp-action="Index">Incidents</a>
                        </li>
                        <li class="nav-item me-3">
                            <a class="nav-link text-white-50 px-3" asp-area="" asp-controller="Resources" asp-action="Index">Resources</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold bg-danger bg-opacity-10 px-3 rounded border border-danger border-opacity-20" asp-area="" asp-controller="Dispatch" asp-action="Create">
                                ⚠️ Dispatch Console
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-shrink-0 mb-5">
        @RenderBody()
    </main>

    <footer class="footer mt-auto py-3 bg-dark border-top border-secondary border-opacity-25">
        <div class="container-fluid px-4 d-flex justify-content-between text-muted small">
            <span>&copy; 2026 - IncidentLink Tactical Command Center</span>
            <div>
                <a class="text-secondary text-decoration-none me-3" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                <span class="text-dark">|</span>
                <span class="text-success ms-3 font-monospace" style="font-size: 0.7rem;">NODE_STATUS // ONLINE</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>