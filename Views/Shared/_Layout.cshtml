<!DOCTYPE html>
<html lang="en" class="h-full scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IncidentLink</title>

    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Inter', sans-serif;
            }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 antialiased selection:bg-cyan-500/30 selection:text-cyan-200 min-h-full flex flex-col">

    <header class="sticky top-0 z-50 border-b border-slate-900 bg-slate-950/70 backdrop-blur-md">
        <div class="max-w-7xl mx-auto px-6 py-3.5 flex items-center justify-between">

            <a asp-controller="Home" asp-action="Index"
                   class="flex items-center gap-2 font-extrabold tracking-tight text-xl text-white group transition">
                   
                <span class="bg-gradient-to-r from-red-500 to-amber-500 bg-clip-text text-transparent group-hover:opacity-80 transition">IncidentLink</span>
            </a>

            <nav class="flex items-center gap-6 text-sm font-medium text-slate-400">
                <a class="hover:text-white transition-colors duration-200 py-1 relative after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-red-500 after:transition-all" asp-controller="Incidents" asp-action="Index">Incidents</a>
                <a class="hover:text-white transition-colors duration-200 py-1 relative after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-0 hover:after:w-full after:bg-red-500 after:transition-all" asp-controller="Resources" asp-action="Index">Resources</a>

                <a asp-controller="Dispatch" asp-action="Create"
                       class="ml-2 px-4 py-1.5 rounded-lg bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 hover:border-cyan-400 hover:bg-cyan-500/20 hover:text-white hover:shadow-[0_0_15px_rgba(6,182,212,0.15)] transition-all duration-300">
                    Dispatch
                </a>
            </nav>

        </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8 flex-1 w-full">
        @RenderBody()
    </main>

    <footer class="border-t border-slate-900 text-slate-600 text-xs py-6 text-center">
        &copy; 2026 IncidentLink &bull; Enterprise Mission Control System
    </footer>

    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>