<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IncidentLink</title>

    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />

    <link rel="stylesheet"
          href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

    <!-- Flowbite -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-slate-100 antialiased">

    <!-- TOP BAR -->
    <header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/70 backdrop-blur-xl">
        <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

            <a asp-controller="Home" asp-action="Index"
                   class="text-white font-semibold tracking-wide">
                IncidentLink
            </a>

            <nav class="flex items-center gap-4 text-sm text-slate-300">

                <a class="hover:text-white transition" asp-controller="Incidents" asp-action="Index">Incidents</a>
                <a class="hover:text-white transition" asp-controller="Resources" asp-action="Index">Resources</a>

                <a asp-controller="Dispatch" asp-action="Create"
                       class="px-3 py-1.5 rounded-lg bg-cyan-500/10 text-cyan-300 border border-cyan-400/20 hover:bg-cyan-500/20 transition">
                    Dispatch
                </a>

            </nav>

        </div>
    </header>

    <!-- MAIN -->
    <main class="max-w-7xl mx-auto px-4 py-6">
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-white/5 text-slate-500 text-sm py-6 text-center">
        © 2026 IncidentLink
    </footer>

    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>