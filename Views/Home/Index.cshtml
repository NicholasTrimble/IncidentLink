@model IncidentLink.Models.DashboardViewModel
@{
    ViewData["Title"] = "Tactical Command Center";
}

<div class="container-fluid px-4 mt-4">
    <!-- Real-Time System Status Header Banner -->
    <div class="row align-items-center mb-4 g-3">
        <div class="col-md-6 text-start">
            <h4 class="mb-1 fw-bold text-white tracking-tight">INCIDENTLINK OPERATIONAL TELEMETRY</h4>
            <div class="d-flex align-items-center gap-2 small text-muted">
                <span class="pulse-indicator"></span>
                <span>SIGNALR LINK ESTABLISHED</span>
                <span class="text-secondary">|</span>
                <span id="sync-time">SYSTEM STATUS: NOMINAL</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="d-flex justify-content-md-end gap-3">
                <div class="px-3 py-2 tac-card text-center min-w-120">
                    <div class="text-uppercase font-monospace text-muted" style="font-size: 0.65rem;">ACTIVE CRISES</div>
                    <span class="h4 fw-bold mb-0 text-warning">@Model.ActiveIncidents.Count</span>
                </div>
                <div class="px-3 py-2 tac-card text-center min-w-120">
                    <div class="text-uppercase font-monospace text-muted" style="font-size: 0.65rem;">UNITS IN RESERVE</div>
                    <span class="h4 fw-bold mb-0 text-success">@Model.AvailableResources.Count</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Command Dashboard Workspace -->
    <div class="row g-4">
        <!-- Live Incident Routing Logs -->
        <div class="col-lg-8">
            <div class="card tac-card h-100">
                <div class="tac-header d-flex justify-content-between align-items-center">
                    <span>⚠️ PRIORITY CRISIS MATRIX</span>
                    <span class="badge bg-dark font-monospace text-secondary">SECURE NODE</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table tac-table align-middle">
                            <thead>
                                <tr>
                                    <th>Incident Profile</th>
                                    <th>Deployment Grid</th>
                                    <th>Threat Metric</th>
                                    <th>Status Flag</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!Model.ActiveIncidents.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-5 font-monospace small">NO PENDING CRISES ENCOUNTERED</td>
                                    </tr>
                                }
                                @foreach (var item in Model.ActiveIncidents)
                                {
                                    <tr>
                                        <td><span class="fw-bold text-white">@item.Title</span></td>
                                        <td><span class="font-monospace text-secondary">@item.Location</span></td>
                                        <td>
                                            <span class="badge font-monospace @(item.Severity.ToString() == "Critical" || item.Severity.ToString() == "High" ? "badge-neon-danger" : "badge-neon-warning")">
                                                @item.Severity
                                            </span>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill font-monospace text-uppercase @(item.Status.ToString() == "Assigned" ? "badge-neon-info" : "badge-neon-warning")">
                                                @item.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right System Resource Column -->
        <div class="col-lg-4">
            <div class="row g-4">
                <!-- Fleet Management Sub-panel -->
                <div class="col-12">
                    <div class="card tac-card">
                        <div class="tac-header font-monospace">🚒 FIELD FLEET READINESS</div>
                        <div class="list-group list-group-flush" style="max-height: 280px; overflow-y: auto;">
                            @if (!Model.AvailableResources.Any())
                            {
                                <div class="p-4 text-center text-muted font-monospace small">ALL UNITS CURRENTLY DISPATCHED</div>
                            }
                            @foreach (var res in Model.AvailableResources)
                            {
                                <div class="list-group-item bg-transparent d-flex justify-content-between align-items-center py-3 border-secondary border-opacity-10">
                                    <div>
                                        <div class="fw-bold text-white mb-0" style="font-size: 0.9rem;">@res.Name</div>
                                        <small class="text-muted font-monospace text-uppercase" style="font-size: 0.7rem;">@res.Type</small>
                                    </div>
                                    <span class="badge badge-neon-success font-monospace small">STANDBY</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Live Audit Logs Sub-panel -->
                <div class="col-12">
                    <div class="card tac-card">
                        <div class="tac-header font-monospace">📋 SYSTEM HISTORICAL TELEMETRY</div>
                        <div class="list-group list-group-flush font-monospace" style="font-size: 0.8rem;">
                            @if (!Model.RecentAssignments.Any())
                            {
                                <div class="p-4 text-center text-muted small">NO TRANSACTION LOGS RECORDED</div>
                            }
                            @foreach (var log in Model.RecentAssignments)
                            {
                                <div class="list-group-item bg-transparent py-3 border-secondary border-opacity-10">
                                    <div class="d-flex justify-content-between text-muted mb-1" style="font-size: 0.7rem;">
                                        <span class="text-info">▲ LOG_ALPHA_TRANS</span>
                                        <span>@log.AssignedAt.ToShortTimeString()</span>
                                    </div>
                                    <div class="text-white-50">
                                        Unit <span class="text-success fw-bold">@log.Resource?.Name</span> mapped securely to <span class="text-warning">@log.Incident?.Title</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/dispatchHub")
        .build();

        connection.on("UpdateDashboard", function () {
        document.getElementById("sync-time").innerText = "SYNCING RECENT DATA CHANGES...";
        window.location.reload();
        });

        connection.start().catch(function (err) {
        console.error(err.toString());
        });
    </script>
}