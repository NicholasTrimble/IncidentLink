@model IncidentLink.Models.DashboardViewModel
@{
    ViewData["Title"] = "Operations Command";
}

<div class="container-fluid mt-3">
    <!-- Top Metrics Header Bar -->
    <div class="row text-center mb-4 g-3">
        <div class="col-md-4">
            <div class="p-3 bg-dark text-white rounded shadow-sm">
                <small class="text-uppercase fw-bold text-muted">Active Emergencies</small>
                <h2 class="display-6 fw-bold mb-0 text-warning">@Model.ActiveIncidents.Count</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-dark text-white rounded shadow-sm">
                <small class="text-uppercase fw-bold text-muted">Available Fleet Units</small>
                <h2 class="display-6 fw-bold mb-0 text-success">@Model.AvailableResources.Count</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3 bg-danger text-white rounded shadow-sm">
                <small class="text-uppercase fw-bold text-white-50">Operational Mode</small>
                <h2 class="h4 fw-bold mb-0 mt-2">LIVE MONITORING</h2>
            </div>
        </div>
    </div>

    <!-- Main Grid Workspace -->
    <div class="row g-4">
        <!-- Active Incidents Column -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-secondary text-white py-3 fw-bold">⚠️ ACTIVE CRISIS QUEUE</div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Emergency</th>
                                    <th>Location</th>
                                    <th>Severity</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.ActiveIncidents)
                                {
                                    <tr>
                                        <td><strong>@item.Title</strong></td>
                                        <td>@item.Location</td>
                                        <td><span class="badge bg-dark">@item.Severity</span></td>
                                        <td><span class="badge bg-primary text-uppercase">@item.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side Panel: Resources & Audit Logs -->
        <div class="col-lg-5">
            <!-- Available Units Card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-secondary text-white py-3 fw-bold">🚒 AVAILABLE UNITS</div>
                <div class="list-group list-group-flush">
                    @foreach (var res in Model.AvailableResources)
                    {
                        <div class="list-group-item d-flex justify-content-between align-middle py-3">
                            <div>
                                <h6 class="mb-0 fw-bold">@res.Name</h6>
                                <small class="text-muted">@res.Type</small>
                            </div>
                            <span class="badge bg-success align-self-center">READY</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Activity Log Card -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-secondary text-white py-3 fw-bold">📋 RECENT DISPATCH LOGS</div>
                <div class="list-group list-group-flush small">
                    @foreach (var log in Model.RecentAssignments)
                    {
                        <div class="list-group-item py-2">
                            <strong>@log.Resource?.Name</strong> deployed to <em>@log.Incident?.Title</em>
                            <div class="text-muted text-end" style="font-size: 0.75rem;">@log.AssignedAt.ToShortTimeString()</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SIGNALR CLIENT SIDE ENGINE -->
@section Scripts {
    <!-- Load the official SignalR JavaScript client library script -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    
    <script>
        // 1. Establish connection to the server tower
        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/dispatchHub")
        .build();

        // 2. Listen for the "UpdateDashboard" radio shout from our server
        connection.on("UpdateDashboard", function () {
        console.log("Real-time broadcast received. Triggering interface sync.");
        // Hot-reload the page contents instantly without losing state
        window.location.reload();
        });

        // 3. Boot up the connection
        connection.start().catch(function (err) {
        return console.error(err.toString());
        });
    </script>
}