@{
    ViewData["Title"] = "Emergency Assignment Control";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold">Emergency Operations Dispatch Console</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-secondary">SELECT ACTIVE INCIDENT</label>
                            <select name="incidentId" class="form-select border-2" asp-items="ViewBag.IncidentId">
                                <option value="">-- Choose Emergency Event --</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-secondary">ASSIGN FIELD RESOURCE</label>
                            <select name="resourceId" class="form-select border-2" asp-items="ViewBag.ResourceId">
                                <option value="">-- Choose Available Unit --</option>
                            </select>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold tracking-wide shadow-sm">
                                AUTHORIZE DISPATCH COMMAND
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>