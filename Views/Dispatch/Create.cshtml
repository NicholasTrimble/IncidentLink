@{
    ViewData["Title"] = "Dispatch Control";
}

<div class="max-w-xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold">Dispatch Control</h1>

    <form asp-action="Create"
          class="space-y-4 bg-gray-900 border border-gray-800 p-6 rounded-xl">

        <div>
            <label class="text-sm text-gray-400">Incident</label>
            <select name="incidentId"
                    asp-items="ViewBag.IncidentId"
                    class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2">
                <option value="">Select Incident</option>
            </select>
        </div>

        <div>
            <label class="text-sm text-gray-400">Resource</label>
            <select name="resourceId"
                    asp-items="ViewBag.ResourceId"
                    class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2">
                <option value="">Select Unit</option>
            </select>
        </div>

        <button class="w-full px-4 py-3 bg-red-600 hover:bg-red-700 rounded-lg text-white font-bold">
            Dispatch Unit
        </button>

    </form>
</div>