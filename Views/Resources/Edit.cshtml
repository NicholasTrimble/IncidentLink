@model IncidentLink.Models.Resource
@{
    ViewData["Title"] = "Edit Resource";
}

<div class="max-w-2xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold">Edit Resource</h1>

    <form asp-action="Edit"
          class="space-y-4 bg-gray-900 border border-gray-800 p-6 rounded-xl">

        <input type="hidden" asp-for="Id" />

        <div>
            <label class="text-sm text-gray-400">Name</label>
            <input asp-for="Name"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2" />
        </div>

        <div>
            <label class="text-sm text-gray-400">Type</label>
            <input asp-for="Type"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2" />
        </div>

        <div>
            <label class="text-sm text-gray-400">Status</label>
            <select asp-for="Status"
                    class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2"></select>
        </div>

        <div>
            <label class="text-sm text-gray-400">Location</label>
            <input asp-for="CurrentLocation"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2" />
        </div>

        <div>
            <label class="text-sm text-gray-400">Capacity</label>
            <input asp-for="Capacity"
                   class="w-full bg-gray-800 border border-gray-700 rounded-lg p-2" />
        </div>

        <button class="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded-lg text-white">
            Save Changes
        </button>

    </form>
</div>