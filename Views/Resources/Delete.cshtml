@model IncidentLink.Models.Resource
@{
    ViewData["Title"] = "Delete Resource";
}

<div class="max-w-2xl mx-auto space-y-6">

    <h1 class="text-2xl font-bold text-red-400">Delete Resource</h1>

    <div class="bg-gray-900 border border-gray-800 p-6 rounded-xl space-y-3">

        <p class="text-gray-300">Are you sure you want to delete this resource?</p>

        <div class="text-sm text-gray-400 space-y-1">
            <div><span class="text-white">Name:</span> @Model.Name</div>
            <div><span class="text-white">Type:</span> @Model.Type</div>
            <div><span class="text-white">Status:</span> @Model.Status</div>
            <div><span class="text-white">Location:</span> @Model.CurrentLocation</div>
            <div><span class="text-white">Capacity:</span> @Model.Capacity</div>
        </div>

        <form asp-action="Delete" class="flex gap-3 mt-4">
            <input type="hidden" asp-for="Id" />

            <button class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg">
                Delete
            </button>

            <a asp-action="Index" class="px-4 py-2 bg-gray-700 rounded-lg">
                Cancel
            </a>
        </form>

    </div>
</div>